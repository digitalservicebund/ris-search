#   rdfs:label "class"@de ;
#   rdfs:comment "What class this point refers to the legislation. Possible values: `book`, `chapter`, `section`, `subsection`, and `article`."@en ;
#   rdfs:comment "What class this point refers to the legislation. Possible values: `book`, `chapter`, `section`, `subsection`, and `article`."@de ;
#   rdfs:subClassOf schema:Text .

