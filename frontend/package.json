{
  "name": "ris-portal-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "test": "TZ=UTC vitest run",
    "test:watch": "TZ=UTC vitest",
    "coverage": "TZ=UTC vitest run --coverage",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "fmt": "oxfmt",
    "lint": "oxlint --fix",
    "style:check": "oxfmt --check && oxlint --max-warnings=0",
    "style:fix": "pnpm fmt && pnpm lint",
    "generate-api-types": "openapi-typescript src/public/openapi.json -o src/types/api-generated.d.ts",
    "typecheck": "nuxt typecheck",
    "audit:licences": "bash -c 'license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow \"$(./parseAllowedLicences.sh)\" --csv --out ./frontend-licence-report.csv'"
  },
  "dependencies": {
    "@digitalservicebund/ris-ui": "4.4.0",
    "@nuxtjs/mdc": "0.22.0",
    "@nuxtjs/sitemap": "8.0.15",
    "@sentry/nuxt": "10.53.1",
    "dayjs": "1.11.20",
    "lodash-es": "4.18.1",
    "minisearch": "7.2.0",
    "nuxt": "4.4.6",
    "nuxt-security": "2.6.0",
    "posthog-js": "1.374.3",
    "primevue": "4.5.5",
    "sanitize-html": "2.17.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@iconify-json/ic": "1.2.4",
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@testing-library/vue": "8.1.0",
    "@types/jsdom": "28.0.3",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.9.1",
    "@types/sanitize-html": "2.16.1",
    "@vitest/coverage-v8": "4.1.7",
    "@vue/test-utils": "2.4.10",
    "axe-html-reporter": "2.2.11",
    "jsdom": "29.1.1",
    "license-checker-rseidelsohn": "4.4.2",
    "lighthouse": "13.3.0",
    "openapi-typescript": "7.13.0",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "playwright-lighthouse": "4.0.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "unplugin-icons": "23.0.1",
    "vitest": "4.1.7",
    "vue-tsc": "3.3.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.4"
}
