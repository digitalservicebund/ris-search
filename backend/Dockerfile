FROM gradle:9.6.1-jdk21@sha256:9795f8c9009a7de6adea522b907c9aadc38fe7c313874112c2b696c8e70b0303
WORKDIR /backend

ARG GH_PACKAGES_REPOSITORY_USER
ARG GH_PACKAGES_REPOSITORY_TOKEN

ENV GH_PACKAGES_REPOSITORY_USER=${GH_PACKAGES_REPOSITORY_USER}
ENV GH_PACKAGES_REPOSITORY_TOKEN=${GH_PACKAGES_REPOSITORY_TOKEN}

COPY --chown=gradle:gradle . /app/backend
WORKDIR /app/backend
EXPOSE 8090
CMD ["gradle", "bootRun"]
