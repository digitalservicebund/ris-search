FROM gradle:9.4.1-jdk21@sha256:5d5fa6d13c61373b8ae5ac11a3a5c9877d0fff04d6f54d24dabb808823527ce0 AS backend-builder
WORKDIR /app
COPY . /app
RUN ./gradlew build -x integrationTest -x test -x spotlessCheck


FROM cgr.dev/chainguard/jre@sha256:2799884f2d68e4264f0eeca10e4b1ae0189af677ae8d37c8a3a817e562fe6c97
ARG SENTRY_RELEASE
COPY --from=backend-builder /app/build/libs/ris-search-*.jar /app/app.jar
EXPOSE 8090
ENV SENTRY_RELEASE=${SENTRY_RELEASE}
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
