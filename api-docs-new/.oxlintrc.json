{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "builtin": true,
    "es2024": true,
    "node": true
  },
  "plugins": [
    "eslint",
    "import",
    "oxc",
    "promise",
    "typescript",
    "unicorn",
    "vue"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "import/no-unassigned-import": "off",
    "typescript/consistent-type-imports": "error",
    "prefer-const": ["error", { "destructuring": "all" }],
    "promise/always-return": "off"
  }
}
